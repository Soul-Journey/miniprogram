<view class="elder-container">
  <view class="ai-header">
    <view class="avatar-wrapper">
      <view class="ai-avatar">🤖</view>
      <view class="ai-status-dot"></view>
    </view>
    <view class="ai-bubble">
      <text class="guide-text">{{currentQuestion}}</text>
    </view>
  </view>

  <scroll-view scroll-y class="history-scroll" scroll-into-view="{{lastId}}">
    <view wx:for="{{memories}}" wx:key="id" id="item-{{item.id}}" class="memory-card">
      <view class="time-tag">{{item.time}}</view>
      <view class="content-text">{{item.content}}</view>
    </view>

    <view wx:if="{{isRecording}}" class="recording-placeholder">
      <view class="pulse-ring"></view>
      <text>正在倾听您的讲述...</text>
    </view>

    <view class="bottom-padding"></view>
  </scroll-view>

  <view class="control-area">

    <view class="hint-text">{{isRecording ? '松开即停止录音' : '按住下方大圆圈开始说话'}}</view>

    <view class="record-trigger {{isRecording ? 'active' : ''}}" bindtouchstart="handleStartRecord" bindtouchend="handleStopRecord">
      <view class="inner-icon">🎙️</view>
    </view>
  </view>
</view>