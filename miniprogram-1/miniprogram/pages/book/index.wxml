<view class="book-container">
  <!-- 自定义导航栏：对应你图中的顶部红框区域 -->
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px">
    <view class="nav-content">
      <view class="nav-title">我的回忆录初稿</view>
    </view>
  </view>

  <!-- 背景装饰 -->
  <view class="book-deck-bg" style="top: {{navBarHeight + 20}}px"></view>
  
  <swiper class="book-swiper" 
          style="margin-top: {{navBarHeight}}px"
          circular="{{false}}" 
          indicator-dots="{{true}}"
          indicator-color="rgba(0,0,0,0.05)"
          indicator-active-color="#FF9A9E">
    
    <swiper-item wx:for="{{pages}}" wx:key="id">
      <view class="paper-page">
        <view class="binding-shadow"></view>
        <view class="page-inner">
          <view class="header-section">
            <block wx:if="{{!item.isContinuation}}">
              <view class="chapter-label">CHAPTER {{index + 1}}</view>
              <view class="chapter-title">{{item.chapterTitle}}</view>
            </block>
            <block wx:else>
              <view class="chapter-title-cont">{{item.chapterTitle}} (续)</view>
            </block>
          </view>

          <view class="photo-box" wx:if="{{item.hasImage}}" bindtap="uploadImg" data-index="{{index}}">
            <image wx:if="{{item.imagePath}}" src="{{item.imagePath}}" mode="aspectFill"></image>
            <view wx:else class="upload-placeholder">
              <text>📸 点击上传关联照片</text>
            </view>
          </view>

          <view class="content-box">
            <text class="article-text">{{item.content}}</text>
          </view>
          
          <view class="footer-pagination">
            <text>第 {{index + 1}} 页</text>
          </view>
        </view>
      </view>
    </swiper-item>
  </swiper>

  <view class="action-bar">
    <button class="export-btn" bindtap="handleExport">导出出版级PDF</button>
  </view>
</view>