page { 
  background-color: #EAE6DF; 
  height: 100%; 
  display: flex; 
  justify-content: center; 
  align-items: center; 
}
.reader-bg { 
  width: 100%; 
  height: 100%; 
  padding: 40rpx 30rpx; 
  box-sizing: border-box; 
}

.book-container { 
  width: 100%; 
  height: 100%; 
  background: #FCFBF7; 
  border-radius: 8rpx 30rpx 30rpx 8rpx; 
  box-shadow: -10rpx 0 30rpx rgba(0,0,0,0.06), 0 20rpx 40rpx rgba(0,0,0,0.1); 
  position: relative; 
  overflow: hidden; 
  display: flex; 
}

.book-spine { 
  width: 40rpx; 
  height: 100%; 
  background: linear-gradient(to right, #E6DFD3 0%, #F5F1E9 30%, #E6DFD3 100%); 
  border-right: 2rpx solid #D5CFC1; 
  flex-shrink: 0; 
  box-shadow: inset -4rpx 0 8rpx rgba(0,0,0,0.03); 
}

.book-content { 
  flex: 1; 
  display: flex; 
  flex-direction: column; 
  padding: 60rpx 10rpx 40rpx 10rpx; /* 减小左右 padding，把空间留给 swiper */
  overflow: hidden; 
}

.book-header { margin-bottom: 20rpx; text-align: center; flex-shrink: 0; padding: 0 20rpx;}
.title { font-size: 40rpx; font-weight: bold; color: #2D2824; display: block; margin-bottom: 24rpx; letter-spacing: 4rpx; }
.author-line { display: flex; justify-content: center; align-items: center; gap: 20rpx; }
.author { font-size: 26rpx; color: #7A7369; }
.style-tag { font-size: 22rpx; color: #D97706; background: #FEF3C7; padding: 4rpx 16rpx; border-radius: 100rpx; }
.divider { width: 60rpx; height: 4rpx; background: #D97706; margin: 30rpx auto 10rpx auto; border-radius: 4rpx; }

/* 🌟 核心：Swiper 翻页系统样式 */
.book-swiper { 
  flex: 1; 
  width: 100%; 
  height: 100%; 
}
.swiper-item-page {
  display: flex;
  flex-direction: column;
  position: relative; /* 为底部页码定位 */
}

/* 隐藏原生滚动条 (多重保险) */
.page-scroll { 
  flex: 1; 
  padding: 0 30rpx 60rpx 30rpx; /* 给底部页码留出空间 */
  box-sizing: border-box;
}
::-webkit-scrollbar {
  width: 0;
  height: 0;
  color: transparent;
  display: none;
}

/* 🌟 章节标题美学 */
.chapter-header {
  margin: 40rpx 0 50rpx 0;
  text-align: center;
}
.chapter-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #5C5246;
  letter-spacing: 6rpx;
}
.chapter-divider {
  width: 40rpx;
  height: 2rpx;
  background: #D5CFC1;
  margin: 20rpx auto 0 auto;
}

/* 📖 核心排版美学 */
.paragraph { 
  display: block; 
  font-size: 32rpx; 
  color: #4A443E; 
  line-height: 2.0; 
  text-indent: 2em; 
  margin-bottom: 44rpx; 
  letter-spacing: 1rpx; 
  text-align: justify; 
}

.drop-cap::first-letter {
  font-size: 80rpx;
  float: left;
  line-height: 1; 
  padding: 12rpx 12rpx 0 0;
  color: #C2410C; 
  font-weight: 900;
  font-family: "楷体", "STKaiti", serif; 
}

/* 🖼️ 图文混排：拍立得老照片相框 */
.photo-frame {
  background: #FFFFFF;
  padding: 16rpx 16rpx 40rpx 16rpx; 
  margin: 60rpx auto;
  box-shadow: 0 16rpx 40rpx rgba(0,0,0,0.08), 0 4rpx 10rpx rgba(0,0,0,0.04); 
  border-radius: 4rpx;
  width: 90%; 
  position: relative;
}
.rotate-left { transform: rotate(-2deg); }
.rotate-right { transform: rotate(1.5deg); }
.photo-img {
  width: 100%; display: block; border-radius: 2rpx; background-color: #EAE6DF; min-height: 300rpx; filter: sepia(0.25) contrast(0.95); 
}
.photo-caption { text-align: center; margin-top: 24rpx; }
.caption-text { font-size: 26rpx; color: #7A7369; font-style: italic; letter-spacing: 2rpx; }
.tape {
  position: absolute; top: -20rpx; left: 50%; transform: translateX(-50%) rotate(-3deg);
  width: 130rpx; height: 40rpx; background: rgba(245, 245, 240, 0.95); 
  box-shadow: 1rpx 2rpx 6rpx rgba(0,0,0,0.08); border: 1rpx solid rgba(0,0,0,0.05);
}

/* 底部页码 */
.page-number {
  position: absolute;
  bottom: 10rpx;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 22rpx;
  color: #A8A29E;
  letter-spacing: 4rpx;
  font-family: monospace;
}

.the-end { text-align: center; font-size: 24rpx; color: #A8A29E; margin: 60rpx 0 40rpx 0; letter-spacing: 4rpx; }

/* 💰 商业承接按钮 */
.book-footer { margin-top: 10rpx; padding: 30rpx 20rpx 0 20rpx; border-top: 2rpx solid #EAE6DF; display: flex; gap: 20rpx; flex-shrink: 0; }
.action-btn { flex: 1; margin: 0; border-radius: 100rpx; font-size: 28rpx; font-weight: bold; height: 80rpx; line-height: 80rpx; }
.action-btn::after { display: none; }
.share-btn { background: #F3F4F6; color: #4B5563; }
.print-btn { background: linear-gradient(135deg, #F59E0B, #EA580C); color: white; box-shadow: 0 8rpx 20rpx rgba(245, 158, 11, 0.3); }
