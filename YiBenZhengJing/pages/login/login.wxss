page { height: 100%; background-color: #f4f4f5; }
.login-container { height: 100vh; display: flex; flex-direction: column; position: relative; overflow: hidden; }

/* 顶部背景区 */
.bg-section {
  flex: 1;
  background: linear-gradient(135deg, #fde68a 0%, #f59e0b 100%);
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 60rpx;
  position: relative;
}
/* 添加一点背景纹理 */
.bg-section::after {
  content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background-image: radial-gradient(rgba(255,255,255,0.2) 2rpx, transparent 2rpx);
  background-size: 30rpx 30rpx; z-index: 1;
}

.brand-text { position: relative; z-index: 2; margin-top: -100rpx; }
.quote { font-size: 32rpx; color: rgba(255, 255, 255, 0.9); margin-bottom: 20rpx; letter-spacing: 4rpx; }
.brand-name { font-size: 72rpx; font-weight: 900; color: #ffffff; letter-spacing: 8rpx; margin-bottom: 16rpx; text-shadow: 0 4rpx 10rpx rgba(217, 119, 6, 0.3); }
.brand-desc { font-size: 28rpx; color: rgba(255, 255, 255, 0.8); }

/* 底部授权卡片 */
.auth-card {
  background: #ffffff;
  border-top-left-radius: 60rpx;
  border-top-right-radius: 60rpx;
  padding: 80rpx 60rpx;
  box-shadow: 0 -10rpx 40rpx rgba(0, 0, 0, 0.05);
  position: relative;
  z-index: 10;
  margin-top: -60rpx; /* 向上重叠一点点 */
}

.card-header { margin-bottom: 60rpx; text-align: center; }
.card-title { font-size: 44rpx; font-weight: bold; color: #27272a; display: block; margin-bottom: 16rpx; }
.card-subtitle { font-size: 28rpx; color: #71717a; }

/* 微信原生绿按钮 */
.wechat-btn {
  background: #07c160; color: #ffffff; font-size: 34rpx; font-weight: bold;
  border-radius: 100rpx; height: 100rpx; display: flex; justify-content: center; align-items: center;
  box-shadow: 0 10rpx 24rpx rgba(7, 193, 96, 0.3); margin-bottom: 40rpx; transition: all 0.2s;
}
.wechat-btn:active { transform: scale(0.96); box-shadow: 0 4rpx 10rpx rgba(7, 193, 96, 0.2); }
.wechat-icon { font-size: 40rpx; margin-right: 12rpx; }

/* 隐私协议区 */
.agreement-box { display: flex; align-items: flex-start; justify-content: center; padding: 0 20rpx; }
.checkbox { width: 32rpx; height: 32rpx; border: 2rpx solid #d4d4d8; border-radius: 8rpx; margin-right: 12rpx; margin-top: 4rpx; display: flex; justify-content: center; align-items: center; font-size: 24rpx; color: white; transition: all 0.2s; flex-shrink: 0; }
.checkbox.checked { background: #07c160; border-color: #07c160; }
.agreement-text { font-size: 24rpx; color: #a1a1aa; line-height: 1.6; flex: 1; }
.link { color: #f59e0b; }
