page { background-color: #F7F8FA; /* 清爽的高级灰白背景 */ }
.page-container { min-height: 100vh; padding: 40rpx 30rpx; box-sizing: border-box; }

/* 顶部问候区 */
.greeting-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 50rpx; margin-top: 20rpx;}
.greeting-text { display: flex; flex-direction: column; }
.greeting-text .title { font-size: 44rpx; font-weight: 800; color: #111827; margin-bottom: 8rpx; letter-spacing: 2rpx;}
.greeting-text .subtitle { font-size: 26rpx; color: #6B7280; }
.greeting-avatar { width: 90rpx; height: 90rpx; background: linear-gradient(135deg, #FCD34D, #F59E0B); border-radius: 50%; display: flex; justify-content: center; align-items: center; box-shadow: 0 4rpx 12rpx rgba(245, 158, 11, 0.3); border: 4rpx solid #fff;}
.default-avatar { font-size: 36rpx; font-weight: bold; color: white; }

/* 新建 Banner */
.create-banner { background: linear-gradient(135deg, #FFFBEB 0%, #FEF3C7 100%); border: 2rpx solid #FDE68A; border-radius: 30rpx; padding: 36rpx 40rpx; display: flex; align-items: center; margin-bottom: 60rpx; box-shadow: 0 8rpx 20rpx rgba(245, 158, 11, 0.08); transition: all 0.2s ease; }
.create-banner:active { transform: scale(0.98); background: #FEF3C7; }
.banner-icon-wrap { position: relative; margin-right: 30rpx; }
.banner-icon { font-size: 64rpx; }
.plus-badge { position: absolute; bottom: -6rpx; right: -10rpx; background: #EA580C; color: white; width: 36rpx; height: 36rpx; border-radius: 50%; display: flex; justify-content: center; align-items: center; font-size: 24rpx; font-weight: bold; border: 4rpx solid #FFFBEB; }
.banner-text { flex: 1; display: flex; flex-direction: column; }
.banner-title { font-size: 34rpx; font-weight: 800; color: #92400E; margin-bottom: 6rpx; }
.banner-desc { font-size: 24rpx; color: #B45309; }
.banner-arrow { font-size: 36rpx; color: #D97706; font-family: monospace; font-weight: bold;}

/* 书架列表区 */
.section-header { display: flex; align-items: baseline; margin-bottom: 30rpx; }
.section-title { font-size: 34rpx; font-weight: 800; color: #1F2937; margin-right: 16rpx; }
.section-count { font-size: 24rpx; color: #9CA3AF; background: #E5E7EB; padding: 4rpx 16rpx; border-radius: 100rpx;}

/* 空状态 */
.empty-state { padding: 80rpx 0; display: flex; flex-direction: column; align-items: center; }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; opacity: 0.8;}
.empty-text { font-size: 26rpx; color: #9CA3AF; }

/* 书本卡片 */
.book-card { background: #FFFFFF; border-radius: 30rpx; padding: 30rpx; margin-bottom: 30rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.03); display: flex; flex-direction: column; }
.book-content { display: flex; align-items: center; padding-bottom: 24rpx; border-bottom: 2rpx dashed #E5E7EB; margin-bottom: 24rpx; }

/* 模拟实体书封面 */
.book-cover { width: 110rpx; height: 140rpx; border-radius: 12rpx; display: flex; justify-content: center; align-items: center; font-size: 50rpx; margin-right: 30rpx; box-shadow: 4rpx 4rpx 10rpx rgba(0,0,0,0.05); position: relative; }
.book-cover::before { content: ''; position: absolute; left: 6rpx; top: 0; bottom: 0; width: 2rpx; background: rgba(0,0,0,0.1); } /* 书脊凹槽效果 */
.cover-elder { background: linear-gradient(135deg, #FEF3C7, #FDE68A); }
.cover-youth { background: linear-gradient(135deg, #ECFDF5, #D1FAE5); }

.book-info { flex: 1; overflow: hidden; }
.book-title { font-size: 32rpx; font-weight: bold; color: #111827; margin-bottom: 12rpx; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.book-tags { margin-bottom: 16rpx; }
.book-tags .tag { background: #F3F4F6; color: #4B5563; font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 6rpx; }

/* 进度条 */
.book-progress-wrap { display: flex; align-items: center; }
.progress-bar { flex: 1; height: 8rpx; background: #F3F4F6; border-radius: 100rpx; margin-right: 16rpx; overflow: hidden; }
.progress-inner { height: 100%; background: #F59E0B; border-radius: 100rpx; transition: width 0.5s ease; }
.progress-text { font-size: 22rpx; color: #6B7280; font-weight: 500; }

/* 操作面板 */
.book-actions { display: flex; justify-content: flex-end; gap: 16rpx; }
.book-actions button { margin: 0; padding: 0 30rpx; height: 60rpx; line-height: 60rpx; font-size: 24rpx; font-weight: bold; border-radius: 100rpx; border: none; }
.book-actions button::after { display: none; } /* 去掉自带边框 */
.btn-secondary { background: #F3F4F6; color: #4B5563; }
.btn-secondary:active { background: #E5E7EB; }
.btn-primary { background: #FFFBEB; color: #D97706; border: 2rpx solid #FDE68A !important; }
.btn-primary:active { background: #FEF3C7; }

/* 确保父级卡片有相对定位，这样绝对定位的删除按钮才能找准位置 */
.book-card {
  position: relative;
  /* ... 你的其他 book-card 样式 ... */
}

/* 新增：删除按钮样式 */
.delete-icon {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.icon-close {
  font-size: 32rpx;
  color: #D1D5DB;
  transition: all 0.2s;
}

.delete-icon:active .icon-close {
  color: #EF4444; /* 点击时变红 */
  transform: scale(1.1);
}
/* --- 醒目的删除按钮 --- */
.delete-btn {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  background: #FEF2F2;
  color: #EF4444;
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  z-index: 10;
  transition: all 0.2s;
  border: 2rpx solid #FEE2E2;
}
.delete-btn:active { transform: scale(0.95); background: #FEE2E2; }
.trash-icon { margin-right: 6rpx; font-size: 24rpx; }


/* --- 自定义高警示删除弹窗 --- */
.custom-modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.6); z-index: 9999; display: flex; justify-content: center; align-items: center; animation: fadeIn 0.3s; }
.custom-modal { background: #fff; width: 80%; border-radius: 40rpx; padding: 60rpx 40rpx 50rpx 40rpx; display: flex; flex-direction: column; align-items: center; box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.2); }

.modal-warning-icon { font-size: 90rpx; margin-bottom: 20rpx; animation: heartbeat 1.5s infinite; }
@keyframes heartbeat { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.1); } }

.modal-title { font-size: 40rpx; font-weight: 900; color: #111827; margin-bottom: 20rpx; }
.modal-content { font-size: 30rpx; color: #4B5563; text-align: center; line-height: 1.6; margin-bottom: 50rpx; width: 100%; }
.highlight-book-name { color: #EF4444; font-weight: 800; font-size: 32rpx;}
.modal-sub-content { font-size: 24rpx; color: #DC2626; margin-top: 16rpx; font-weight: bold; background: #FEF2F2; padding: 12rpx; border-radius: 12rpx; border: 2rpx dashed #FCA5A5;}

.modal-actions { display: flex; width: 100%; gap: 20rpx; }
.modal-btn { flex: 1; height: 88rpx; line-height: 88rpx; border-radius: 100rpx; font-size: 30rpx; font-weight: bold; margin: 0; padding: 0; }
.modal-btn::after { display: none; }
.modal-btn.cancel { background: #F3F4F6; color: #4B5563; }
.modal-btn.cancel:active { background: #E5E7EB; }

/* 倒计时状态控制 */
.modal-btn.confirm { background: #EF4444; color: white; transition: all 0.3s; }
.modal-btn.confirm.disabled { background: #FCA5A5; color: #fff; pointer-events: none; } /* 倒计时未结束不可点击 */
.modal-btn.confirm.active { background: #EF4444; box-shadow: 0 8rpx 20rpx rgba(239, 68, 68, 0.3); }
.modal-btn.confirm.active:active { transform: scale(0.96); background: #DC2626; }
