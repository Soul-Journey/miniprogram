page { height: 100%; background-color: #F7F4ED; }

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 纸质网格背景纹理 */
.chat-bg-pattern {
  background-image: radial-gradient(#d4d4d8 2rpx, transparent 2rpx);
  background-size: 40rpx 40rpx;
  background-color: #F7F4ED;
}

/* 🌟 新增：章节引导悬浮栏 */
.chapter-guide {
  background-color: rgba(255, 244, 229, 0.95);
  backdrop-filter: blur(10px);
  padding: 20rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
  z-index: 10;
  border-bottom: 2rpx solid #FDE68A;
}

.guide-info { display: flex; flex-direction: column; }
.guide-label { font-size: 20rpx; color: #D97706; margin-bottom: 4rpx; font-weight: bold;}
.guide-title { font-size: 28rpx; color: #92400E; font-weight: 800; }

.finish-chapter-btn {
  background: linear-gradient(135deg, #F59E0B, #EA580C);
  color: white;
  font-size: 24rpx;
  font-weight: bold;
  padding: 16rpx 28rpx;
  border-radius: 100rpx;
  box-shadow: 0 4rpx 10rpx rgba(234, 88, 12, 0.3);
}
.finish-chapter-btn:active { transform: scale(0.95); }

/* 撤回提示文字 */
.recall-tip {
  text-align: center;
  margin-top: 40rpx;
}
.recall-tip text {
  font-size: 22rpx;
  color: #A8A29E;
  background: rgba(0,0,0,0.04);
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
}
.finish-chapter-btn:active { transform: scale(0.95); }

/* 注释掉旧的 elder-tips，因为被新的 guide 取代了 */
.elder-tips { display: none; }

.time-stamp { text-align: center; font-size: 22rpx; color: #a1a1aa; margin: 20rpx 0; 
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 70rpx;
  margin-bottom: 30rpx;
  transform: rotate(-5deg);
  box-shadow: 0 10rpx 30rpx rgba(249, 115, 22, 0.3);
}

.welcome-title { font-size: 40rpx; font-weight: bold; color: #27272a; margin-bottom: 16rpx; }
.welcome-desc { font-size: 28rpx; color: #71717a; text-align: center; padding: 0 40rpx; line-height: 1.6; }

.quick-replies { width: 100%; margin-top: 60rpx; }
.quick-title { font-size: 24rpx; font-weight: bold; color: #a1a1aa; margin-bottom: 20rpx; margin-left: 10rpx; }

.quick-btn {
  background: rgba(255, 255, 255, 0.8);
  border: 2rpx solid #fef3c7;
  padding: 30rpx;
  border-radius: 30rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
  transition: all 0.2s;
}
.quick-btn:active { transform: scale(0.98); background: #fef3c7; }
.quick-emoji { font-size: 40rpx; margin-right: 20rpx; width: 80rpx; height: 80rpx; background: #fffbeb; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
.quick-text { font-size: 30rpx; color: #3f3f46; font-weight: bold; }

/* --- 聊天气泡 --- */
.message-row { display: flex; margin-bottom: 40rpx; align-items: flex-start; }
.row-left { flex-direction: row; }
.row-right { flex-direction: row-reverse; }

.avatar { width: 80rpx; height: 80rpx; border-radius: 50%; display: flex; justify-content: center; align-items: center; color: white; font-size: 32rpx; font-weight: bold; margin: 0 20rpx; border: 4rpx solid #fff; box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05); flex-shrink: 0; }
.avatar-ai { background: linear-gradient(135deg, #fbbf24, #f97316); }
.avatar-user { background-color: #3f3f46; }

.bubble { max-width: 65%; padding: 28rpx 32rpx; border-radius: 30rpx; font-size: 32rpx; line-height: 1.6; word-wrap: break-word; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03); }
.bubble-ai { background-color: #ffffff; color: #27272a; border-top-left-radius: 8rpx; border: 2rpx solid #fef3c7; }
.bubble-user { background: linear-gradient(135deg, #fef3c7, #ffedd5); color: #7c2d12; border-top-right-radius: 8rpx; border: 2rpx solid #fde68a; font-weight: 500; }

.bottom-spacer { height: 40rpx; }

/* --- 底部输入区 --- */
.input-area {
  background-color: #F7F4ED;
  border-top: 2rpx solid rgba(253, 230, 138, 0.5);
  padding: 24rpx 40rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  position: relative;
}

.record-btn {
  width: 100% !important;
  height: 110rpx;
  background: linear-gradient(90deg, #f59e0b, #ea580c);
  border-radius: 100rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  color: white;
  box-shadow: 0 16rpx 40rpx rgba(234, 88, 12, 0.25);
  z-index: 2;
  transition: all 0.2s;
}

.record-btn.recording {
  background: #a1a1aa;
  box-shadow: none;
  transform: scale(0.96);
}

.btn-icon { font-size: 44rpx; margin-right: 16rpx; }
.btn-text { font-size: 36rpx; font-weight: bold; letter-spacing: 2rpx; }

/* 录音波纹 */
.voice-ripple { position: absolute; left: 40rpx; right: 40rpx; top: 24rpx; height: 110rpx; background: #fcd34d; border-radius: 100rpx; opacity: 0; z-index: 1; }
.voice-ripple.active { animation: pulse 1.5s infinite; }
@keyframes pulse { 0% { transform: scale(1); opacity: 0.8; } 100% { transform: scale(1.1); opacity: 0; } }

/* 打字机动画 */
.typing-indicator { display: flex; align-items: center; height: 48rpx; }
.typing-dot { width: 12rpx; height: 12rpx; background-color: #a1a1aa; border-radius: 50%; margin: 0 6rpx; animation: typing 1.4s infinite ease-in-out both; }
.typing-dot:nth-child(1) { animation-delay: -0.32s; }
.typing-dot:nth-child(2) { animation-delay: -0.16s; }
@keyframes typing { 0%, 80%, 100% { transform: scale(0); } 40% { transform: scale(1); } }
@keyframes fadeIn { from { opacity: 0; transform: translateY(20rpx); } to { opacity: 1; transform: translateY(0); } }